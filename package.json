{
  "name": "rn-usb-camera",
  "version": "0.2.0",
  "description": "React Native library for Android USB (UVC) camera powered by AUSBC",
  "main": "src/index",
  "source": "src/index.ts",
  "types": "src/index.ts",
  "react-native": "src/index.ts",
  "files": [
    "src",
    "android",
    "!android/build",
    "!**/__tests__"
  ],
  "scripts": {
    "sync:ausbc": "./scripts/sync-ausbc.sh",
    "typescript": "tsc --noEmit"
  },
  "codegenConfig": {
    "name": "RnUsbCameraSpec",
    "type": "modules",
    "jsSrcsDir": "./src",
    "android": {
      "javaPackageName": "com.rnusbcamera"
    }
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-native": ">=0.80"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
